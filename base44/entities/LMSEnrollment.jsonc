{
  "name": "LMSEnrollment",
  "type": "object",
  "properties": {
    "target_type": {
      "type": "string",
      "title": "Assignment Target",
      "enum": [
        "student",
        "staff"
      ],
      "default": "student"
    },
    "student_name": {
      "type": "string",
      "title": "Student / Staff Name"
    },
    "student_email": {
      "type": "string",
      "title": "Student / Staff Email"
    },
    "participant_id": {
      "type": "string",
      "title": "Participant ID"
    },
    "staff_id": {
      "type": "string",
      "title": "Staff Member ID"
    },
    "course_id": {
      "type": "string",
      "title": "Course ID"
    },
    "course_title": {
      "type": "string",
      "title": "Course Title"
    },
    "assigned_by": {
      "type": "string",
      "title": "Assigned By"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "Assigned",
        "In Progress",
        "Completed"
      ],
      "default": "Assigned"
    },
    "completed_at": {
      "type": "string",
      "title": "Completed At"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    }
  },
  "required": [
    "student_name",
    "course_id"
  ]
}